# EmailJS (contato — opcional se a página de contato não for usada no blog)
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=

# URL base do portfólio (Next.js). Usada para links externos na navbar e redirects.
# Produção: https://www.yurimachado.dev.br
# Local:    http://localhost:3000 (padrão automático em `pnpm dev` via config.ts)
PUBLIC_PORTFOLIO_URL=https://www.yurimachado.dev.br
