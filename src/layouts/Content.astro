---
import Sidebar from "@ui/Sidebar.astro";
import TOC from "@ui/TOC.astro";
import Footer from "./Footer.astro";
import Navbar from "./Navbar.astro";
import type { SidebarEntry } from "../types";
import ThemeInit from "@shared/ThemeInit.astro";
import Head from "./Head.astro";
import { ChevronLeftRaw, CloseRaw, MenuRaw } from "@assets";
import { localeFromPath } from "@/lib/locale-cookie";
import { htmlLang } from "@i18n/index";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  sidebar?: SidebarEntry[];
  headings?: Heading[];
  locale?: "pt" | "en";
}

const { title, description, sidebar, headings = [], locale: localeProp } =
  Astro.props;
const locale = localeProp ?? localeFromPath(Astro.url.pathname);
const hasSidebar = sidebar && sidebar.length > 0;
const hasToc =
  headings.filter((h) => h.depth === 2 || h.depth === 3).length > 0;
---

<html lang={htmlLang(locale)}>
  <ThemeInit />
  <Head title={title} description={description} locale={locale} />

  <body>
    <Navbar transition:persist="navbar" />
    <main
      class="posts-layout pt-16 md:pt-20"
      data-has-sidebar={hasSidebar ? "true" : "false"}
      data-has-toc={hasToc ? "true" : "false"}
    >
      {
        hasSidebar && (
          <aside class="posts-sidebar" transition:name="posts-sidebar">
            <div class="posts-sidebar-header">
              <button
                type="button"
                class="posts-sidebar-close"
                aria-label="Fechar navegação"
              >
                <span aria-hidden="true" set:html={CloseRaw} />
              </button>
            </div>
            <Sidebar entries={sidebar} />
            {hasToc && (
              <div class="mobile-toc-section">
                <div class="mobile-toc-divider" />
                <nav aria-label="Nesta página">
                  <p class="mobile-toc-label">Nesta página</p>
                  <ul class="mobile-toc-list">
                    {headings
                      .filter((h) => h.depth === 2 || h.depth === 3)
                      .map((heading) => (
                        <li>
                          <a
                            href={`#${heading.slug}`}
                            class:list={[
                              "mobile-toc-link",
                              heading.depth === 3 && "mobile-toc-link--h3",
                            ]}
                            data-mobile-toc-link
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                  </ul>
                </nav>
              </div>
            )}
          </aside>
        )
      }
      {
        hasSidebar && (
          <button class="sidebar-toggle" aria-label="Colapsar navegação">
            <span aria-hidden set:html={ChevronLeftRaw} />
          </button>
        )
      }

      {
        hasSidebar && (
          <div class="posts-mobile-bar">
            <button
              type="button"
              class="sidebar-mobile-toggle"
              aria-label="Abrir navegação"
              aria-expanded="false"
            >
              <span
                class="sidebar-mobile-toggle-icon"
                data-icon-menu
                aria-hidden="true"
                set:html={MenuRaw}
              />
              <span
                class="sidebar-mobile-toggle-icon is-icon-hidden"
                data-icon-close
                aria-hidden="true"
                set:html={CloseRaw}
              />
            </button>
          </div>
        )
      }

      <div class="sidebar-backdrop"></div>

      <article class="posts-content prose min-w-0">
        <h1 class="posts-title">{title}</h1>
        {description && <p class="posts-lead">{description}</p>}
        <slot />
      </article>

      {
        hasToc && (
          <aside class="posts-toc">
            <TOC headings={headings} />
          </aside>
        )
      }

      <div class="posts-footer">
        <Footer />
      </div>
    </main>
  </body>
</html>

<style>
  /* Grid layout driven by data attributes */
  .posts-layout {
    display: grid;
    min-height: 100svh;
    align-items: start;
    transition: grid-template-columns 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .posts-layout[data-has-sidebar="true"][data-has-toc="true"] {
    grid-template-columns: 16rem 1fr 14rem;
  }
  .posts-layout[data-has-sidebar="true"][data-has-toc="false"] {
    grid-template-columns: 16rem 1fr;
  }
  .posts-layout[data-has-sidebar="false"][data-has-toc="true"] {
    grid-template-columns: 1fr 14rem;
  }
  .posts-layout[data-has-sidebar="false"][data-has-toc="false"] {
    grid-template-columns: 1fr;
  }

  /* Collapsed sidebar */
  .posts-layout.sidebar-collapsed[data-has-toc="true"] {
    grid-template-columns: 0 1fr 14rem;
  }
  .posts-layout.sidebar-collapsed[data-has-toc="false"] {
    grid-template-columns: 0 1fr;
  }
  .posts-layout.sidebar-collapsed .posts-sidebar {
    border-right: none;
    overflow: hidden;
    padding: 0;
  }

  .posts-sidebar {
    position: sticky;
    top: 4rem;
    height: calc(100svh - 4rem);
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
    transition:
      opacity 0.25s ease,
      padding 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (min-width: 48rem) {
    .posts-sidebar {
      top: 5rem;
      height: calc(100svh - 5rem);
    }
  }

  .posts-layout.sidebar-collapsed .posts-sidebar {
    opacity: 0;
  }

  .sidebar-toggle {
    position: fixed;
    top: 6rem;
    left: 15.5rem;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 36px;
    border-radius: 0 6px 6px 0;
    border: 1px solid var(--color-border);
    border-left: none;
    background: var(--color-surface);
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 150ms ease,
      background 150ms ease,
      left 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.25s ease;
  }
  .sidebar-toggle:hover {
    color: var(--color-text);
    background: rgb(255 255 255 / 0.08);
  }
  .posts-layout.sidebar-collapsed .sidebar-toggle {
    left: 0;
    transform: rotate(180deg);
  }

  .sidebar-mobile-toggle {
    display: none;
  }

  .posts-mobile-bar {
    display: none;
  }

  .posts-sidebar-header {
    display: none;
  }

  .sidebar-backdrop {
    display: none;
  }

  .mobile-toc-section {
    display: none;
  }

  .posts-content {
    padding: 3rem;
    max-width: none;
    overflow-x: clip;
  }

  .posts-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  @media (min-width: 40rem) {
    .posts-title {
      font-size: 3rem;
    }
  }

  .posts-lead {
    font-size: 1.25rem;
    color: var(--color-muted);
    line-height: 1.625;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .posts-toc {
    position: sticky;
    top: 6rem;
    padding: 0 1.5rem 3rem 0;
  }

  .posts-footer {
    grid-column: 1 / -1;
  }
  .posts-layout[data-has-sidebar="true"] .posts-footer {
    grid-column: 2 / -1;
  }
  .posts-layout.sidebar-collapsed .posts-footer {
    grid-column: 1 / -1;
  }
  .posts-footer :global(.footer) {
    margin-top: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .posts-layout[data-has-sidebar],
    .posts-layout[data-has-sidebar="true"][data-has-toc="true"],
    .posts-layout[data-has-sidebar="true"][data-has-toc="false"],
    .posts-layout.sidebar-collapsed[data-has-toc="true"],
    .posts-layout.sidebar-collapsed[data-has-toc="false"] {
      grid-template-columns: 1fr !important;
    }

    .posts-toc {
      display: none;
    }

    .posts-sidebar {
      position: fixed;
      left: 0;
      top: 4rem;
      height: calc(100dvh - 4rem);
      width: min(16rem, 85vw);
      /* Stay below the fixed navbar (z-50) so the logo, ThemeToggle,
         LocaleToggle and hamburger remain visible and clickable while
         the sidebar drawer is open. */
      z-index: 45;
      background: var(--color-bg);
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      border-right: 1px solid var(--color-border);
      overflow: hidden;
      padding: 0;
      opacity: 1;
    }
    .posts-sidebar.is-open {
      transform: translateX(0);
      overflow-y: auto;
      padding: initial;
    }

    .posts-sidebar-header {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0.75rem 0.75rem 0.25rem;
    }
    .posts-sidebar-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border: none;
      border-radius: 6px;
      background: transparent;
      color: var(--color-muted);
      cursor: pointer;
      transition:
        color 150ms ease,
        background 150ms ease;
    }
    .posts-sidebar-close:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.08);
    }
    .posts-sidebar-close :global(svg) {
      width: 1.125rem;
      height: 1.125rem;
      display: block;
    }

    .posts-mobile-bar {
      display: block;
      position: sticky;
      top: 4rem;
      z-index: 40;
      padding: 1rem 1.25rem 0;
      background: linear-gradient(
        to bottom,
        var(--color-bg) 70%,
        transparent
      );
    }

    .sidebar-toggle {
      display: none;
    }

    .sidebar-mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem;
      border-radius: 8px;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-muted);
      cursor: pointer;
      transition:
        color 150ms ease,
        background 150ms ease,
        border-color 150ms ease;
    }
    .sidebar-mobile-toggle:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.08);
    }
    .sidebar-mobile-toggle-icon {
      display: inline-flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      width: 1.25rem;
      height: 1.25rem;
    }
    .sidebar-mobile-toggle-icon :global(svg) {
      width: 1.25rem;
      height: 1.25rem;
      display: block;
    }
    .sidebar-mobile-toggle-icon.is-icon-hidden {
      display: none;
    }

    .sidebar-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      top: 4rem;
      z-index: 44;
      background: rgb(0 0 0 / 0.55);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .sidebar-backdrop.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .mobile-toc-section {
      display: block;
      padding: 0 1rem 1.5rem;
    }
    .mobile-toc-divider {
      height: 1px;
      background: var(--color-border);
      margin-bottom: 1.25rem;
    }
    .mobile-toc-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-muted);
      margin-bottom: 0.5rem;
    }
    .mobile-toc-list {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .mobile-toc-link {
      display: block;
      padding: 0.3125rem 0.75rem;
      border-radius: 6px;
      font-size: 0.8125rem;
      color: var(--color-muted);
      text-decoration: none;
      transition: color 150ms ease, background 150ms ease;
    }
    .mobile-toc-link:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.05);
    }
    .mobile-toc-link--h3 {
      padding-left: 1.25rem;
      font-size: 0.75rem;
    }

    .posts-content {
      padding: 1rem 1.25rem 2rem;
    }

    .posts-footer {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) and (prefers-reduced-motion: reduce) {
    .posts-sidebar,
    .sidebar-backdrop {
      transition: none;
    }
  }
</style>

<script>
  import { setScrollLock } from "@shared/handlers/scroll-lock";

  function initPosts() {
    const layout = document.querySelector<HTMLElement>(".posts-layout");
    const sidebar = document.querySelector<HTMLElement>(".posts-sidebar");
    const toggle = document.querySelector<HTMLElement>(".sidebar-toggle");
    const mobileToggle = document.querySelector<HTMLElement>(
      ".sidebar-mobile-toggle",
    );
    const backdrop = document.querySelector<HTMLElement>(".sidebar-backdrop");

    if (layout && toggle) {
      if (localStorage.getItem("posts-sidebar-collapsed") === "true") {
        layout.classList.add("sidebar-collapsed");
      }
      toggle.addEventListener("click", () => {
        const collapsed = layout.classList.toggle("sidebar-collapsed");
        localStorage.setItem("posts-sidebar-collapsed", String(collapsed));
      });
    }

    if (sidebar && mobileToggle && backdrop) {
      const LOCK_ID = "posts-sidebar";
      const iconMenu = mobileToggle.querySelector<HTMLElement>("[data-icon-menu]");
      const iconClose = mobileToggle.querySelector<HTMLElement>("[data-icon-close]");
      const sidebarClose = sidebar.querySelector<HTMLButtonElement>(".posts-sidebar-close");

      function getFocusable() {
        return Array.from(
          sidebar!.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled])',
          ),
        );
      }

      function openSidebar() {
        sidebar!.classList.add("is-open");
        backdrop!.classList.add("is-open");
        setScrollLock(LOCK_ID, true);
        mobileToggle!.setAttribute("aria-expanded", "true");
        mobileToggle!.setAttribute("aria-label", "Fechar navegação");
        iconMenu?.classList.add("is-icon-hidden");
        iconClose?.classList.remove("is-icon-hidden");
        // Move focus into the drawer for keyboard/screen-reader users.
        sidebarClose?.focus();
      }

      function closeSidebar(options: { restoreFocus?: boolean } = {}) {
        const wasOpen = sidebar!.classList.contains("is-open");
        sidebar!.classList.remove("is-open");
        backdrop!.classList.remove("is-open");
        setScrollLock(LOCK_ID, false);
        mobileToggle!.setAttribute("aria-expanded", "false");
        mobileToggle!.setAttribute("aria-label", "Abrir navegação");
        iconMenu?.classList.remove("is-icon-hidden");
        iconClose?.classList.add("is-icon-hidden");
        if (wasOpen && options.restoreFocus) {
          mobileToggle!.focus();
        }
      }

      mobileToggle.addEventListener("click", () => {
        if (sidebar!.classList.contains("is-open")) {
          closeSidebar({ restoreFocus: true });
        } else {
          openSidebar();
        }
      });
      sidebarClose?.addEventListener("click", () =>
        closeSidebar({ restoreFocus: true }),
      );
      backdrop.addEventListener("click", () => closeSidebar());

      document.addEventListener("keydown", (e) => {
        if (!sidebar!.classList.contains("is-open")) return;

        if (e.key === "Escape") {
          closeSidebar({ restoreFocus: true });
          return;
        }

        // Simple focus trap: keep Tab cycling within the open drawer.
        if (e.key === "Tab") {
          const focusable = getFocusable();
          if (focusable.length === 0) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          const active = document.activeElement;

          if (e.shiftKey && active === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && active === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });

      // Any navigation from within the drawer (post links, TOC links, or
      // the "Início" link) should close it so scroll unlocks and the
      // backdrop doesn't linger through the page transition.
      sidebar.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
        link.addEventListener("click", () => closeSidebar());
      });

      // Safety net: never leave scroll locked across a page transition,
      // even if the drawer was closed some other way.
      document.addEventListener(
        "astro:before-preparation",
        () => setScrollLock(LOCK_ID, false),
        { once: true },
      );
    }
  }

  document.addEventListener("astro:page-load", initPosts);
</script>
