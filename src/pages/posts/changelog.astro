---
import { Content } from "@layouts";
import { getChangelogs } from "@shared";
import { buildDocsSidebar } from "@shared";
import { render } from "astro:content";
import { getMessages } from "@i18n/index";

const messages = getMessages("pt");
const currentPath = Astro.url.pathname;
const sidebar = await buildDocsSidebar(currentPath);
const changelogs = await getChangelogs();

const rendered = await Promise.all(
  changelogs.map(async (entry) => {
    const { Content: Body } = await render(entry);
    const projectSlug =
      entry.id === "changelog" ? "sobre" : entry.id.replace(/\/changelog$/, "");
    return {
      id: entry.id,
      title: entry.data.title,
      description: entry.data.description,
      projectHref: `/posts/portfolio/${projectSlug}`,
      Body,
    };
  }),
);
---

<Content
  title={messages.changelog.title}
  description={messages.changelog.lead}
  sidebar={sidebar}
  headings={[]}
>
  {
    rendered.length > 0 ? (
      <div class="changelog-stack">
        {rendered.map(({ id, title, description, projectHref, Body }) => (
          <section class="changelog-block" id={id.replace(/\//g, "-")}>
            <header class="changelog-header">
              <h2 class="changelog-project">
                <a href={projectHref}>{title}</a>
              </h2>
              {description && <p class="posts-lead-inline">{description}</p>}
            </header>
            <Body />
          </section>
        ))}
      </div>
    ) : (
      <p>{messages.changelog.empty}</p>
    )
  }
</Content>

<style>
  .changelog-stack {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .changelog-block {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .changelog-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .changelog-header {
    margin-bottom: 1.5rem;
  }

  .changelog-project {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .changelog-project a {
    color: inherit;
    text-decoration: none;
  }

  .changelog-project a:hover {
    color: var(--color-primary-400);
  }

  .posts-lead-inline {
    color: var(--color-muted);
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }
</style>
