---
import { Base } from "@layouts";
import { CONFIG, portfolioUrl } from "@config";
import { getAllNotes } from "@shared";
import Button from "@ui/Button.astro";
import PageHeader from "@ui/PageHeader.astro";
import { pt } from "@i18n/pt";

const notes = await getAllNotes();

function formatDate(date: Date) {
  return date.toLocaleDateString("pt-BR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base
  title="Publicações"
  description={CONFIG.meta.description}
>
  <PageHeader title={pt.home.title} lead={pt.home.lead}>
    <Button href={portfolioUrl()} variant="outline" size="lg">
      {pt.home.portfolioCta}
    </Button>
  </PageHeader>

  <section class="site-container pb-16 md:pb-20">
      {
        notes.length > 0 ? (
          <ul class="posts-list list-none p-0 m-0">
            {notes.map((note) => (
              <li class="post-item">
                <a href={`/docs/notes/${note.id}`} class="post-card card-glow-subtle">
                  <span class="article-title">{note.data.title}</span>
                  {(note.data.description || note.data.pubDate) && (
                    <span class="article-meta">
                      {note.data.description}
                      {note.data.description && note.data.pubDate && " — "}
                      {note.data.pubDate && formatDate(new Date(note.data.pubDate))}
                    </span>
                  )}
                  {note.data.tags && note.data.tags.length > 0 && (
                    <span class="post-tags">
                      {note.data.tags.map((tag: string) => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="article-meta">{pt.notes.empty}</p>
        )
      }
    </section>
</Base>

<style>
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-text);
    transition:
      color 300ms ease,
      border-color 300ms ease,
      box-shadow 300ms ease,
      transform 300ms ease;
  }

  .post-card:hover {
    color: var(--color-primary-400);
    border-color: color-mix(in srgb, var(--color-primary) 45%, transparent);
    box-shadow: var(--shadow-card-hover-subtle);
    transform: translateY(-2px);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .post-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
</style>
