---
import ReactButton from "./Button.tsx";

interface Props {
  children?: any;
  href?: string;
  style?: {
    variant?: "primary" | "muted";
    size?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl" | "3xl" | "4xl";
    animation?: "spring" | "smooth";
  };
  onClick?: any;
  target?: string;
  rel?: string;
  title?: string;
  class?: string;
}

const { style, children, ...props } = Astro.props as Props;
---

<ReactButton client:load style={style} {...props}>
  <slot>{children}</slot>
</ReactButton>
