---
import { MoonRaw, SunRaw } from "@assets";
---

<button
  type="button"
  data-theme-toggle
  class="inline-flex size-9 shrink-0 items-center justify-center rounded-4xl text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
  aria-label="Alternar tema"
>
  <span
    data-theme-icon="sun"
    class="size-5 [&_svg]:size-5"
    aria-hidden
    set:html={SunRaw}
  />
  <span
    data-theme-icon="moon"
    class="size-5 [&_svg]:size-5"
    aria-hidden
    set:html={MoonRaw}
  />
</button>

<script>
  import {
    getCurrentTheme,
    reapplyTheme,
    toggleTheme,
  } from "@shared/handlers/theme";

  function syncToggleLabels() {
    const isDark = getCurrentTheme() === "dark";
    document.documentElement.dataset.theme = isDark ? "dark" : "light";
    document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
      toggle.setAttribute(
        "aria-label",
        isDark ? "Ativar tema claro" : "Ativar tema escuro",
      );
    });
  }

  function initThemeToggle() {
    reapplyTheme();
    syncToggleLabels();
    document
      .querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
      .forEach((toggle) => {
        if (toggle.dataset.themeInit) return;
        toggle.dataset.themeInit = "1";
        toggle.addEventListener("click", () => {
          toggleTheme();
          syncToggleLabels();
        });
      });
  }

  function onAfterSwap() {
    reapplyTheme();
    syncToggleLabels();
  }

  document.addEventListener("astro:page-load", initThemeToggle);
  document.addEventListener("astro:after-swap", onAfterSwap);
</script>
