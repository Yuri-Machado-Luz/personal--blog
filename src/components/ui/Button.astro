---
import { cn } from "@shared";

type Variant = "primary" | "outline";
type Size = "sm" | "md" | "lg" | "xl";

interface Props {
  href?: string;
  target?: string;
  rel?: string;
  title?: string;
  download?: boolean | string;
  class?: string;
  variant?: Variant;
  size?: Size;
}

const {
  variant = "outline",
  size = "md",
  class: className,
  ...props
} = Astro.props;

const variants: Record<Variant, string> = {
  primary:
    "border border-transparent bg-primary-400 text-[#f2f4f3] [animation:ambientGlow_3s_ease-in-out_infinite] hover:bg-primary-400/80 hover:scale-[1.02] active:scale-[0.98]",
  outline:
    "border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] hover:border-primary-400/50 hover:bg-[var(--color-surface-strong)] hover:text-[var(--color-text)] hover:shadow-[var(--shadow-link-hover)] active:scale-[0.98] dark:bg-transparent dark:hover:bg-[rgb(255_255_255/0.08)]",
};

const sizes: Record<Size, string> = {
  sm: "h-8 gap-1 px-3 text-sm",
  md: "h-9 gap-1.5 px-3 text-sm",
  lg: "h-10 gap-1.5 px-4 text-sm",
  xl: "h-10 gap-1.5 px-4 text-base",
};
---

<a
  class={cn(
    "inline-flex shrink-0 items-center justify-center w-fit cursor-pointer rounded-[calc(var(--radius-lg)*2.6)] border border-transparent font-medium whitespace-nowrap select-none transition-all outline-none duration-200 ease-out",
    variants[variant],
    sizes[size],
    className,
  )}
  {...props}
>
  <slot />
</a>
