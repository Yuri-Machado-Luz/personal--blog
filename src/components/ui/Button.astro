---
import { cn } from "@shared";

type Variant = "primary" | "outline" | "default";
type Size = "sm" | "md" | "lg" | "xl" | "default";

interface Props {
  href?: string;
  target?: string;
  rel?: string;
  title?: string;
  download?: boolean | string;
  class?: string;
  variant?: Variant;
  size?: Size;
}

const {
  variant = "outline",
  size = "md",
  class: className,
  ...props
} = Astro.props;

const resolvedVariant = variant === "default" ? "primary" : variant;
const resolvedSize = size === "default" ? "md" : size;

const variants: Record<"primary" | "outline", string> = {
  primary:
    "border border-transparent bg-primary text-primary-foreground [animation:ambientGlow_3s_ease-in-out_infinite] hover:bg-primary/80 hover:scale-[1.02] active:scale-[0.98]",
  outline:
    "border border-border bg-background text-foreground hover:border-primary/50 hover:bg-muted hover:text-foreground hover:shadow-[var(--shadow-link-hover)] active:scale-[0.98] dark:bg-transparent dark:hover:bg-input/30",
};

const sizes: Record<"sm" | "md" | "lg" | "xl", string> = {
  sm: "h-8 gap-1 px-3 text-sm",
  md: "h-9 gap-1.5 px-3 text-sm",
  lg: "h-10 gap-1.5 px-4 text-sm",
  xl: "h-10 gap-1.5 px-4 text-base",
};
---

<a
  class={cn(
    "inline-flex shrink-0 items-center justify-center w-fit cursor-pointer rounded-4xl border border-transparent font-medium whitespace-nowrap select-none transition-all outline-none duration-200 ease-out",
    variants[resolvedVariant],
    sizes[resolvedSize],
    className,
  )}
  {...props}
>
  <slot />
</a>
