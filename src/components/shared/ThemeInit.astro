---
/** Blocking theme init + icon visibility: must render before global.css.
 *  Resolution: cookie → localStorage → prefers-color-scheme
 */
---
<script is:inline>
  (function () {
    var key = "theme";
    try {
      var cookieMatch = document.cookie.match(/(?:^|;\s*)theme=(light|dark|system)(?:;|$)/);
      var fromCookie = cookieMatch ? cookieMatch[1] : null;
      var fromStorage = localStorage.getItem(key);
      var stored =
        fromCookie ||
        (fromStorage === "light" ||
        fromStorage === "dark" ||
        fromStorage === "system"
          ? fromStorage
          : null);
      var prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      var isDark = prefersDark;
      if (stored === "light") isDark = false;
      else if (stored === "dark") isDark = true;
      else isDark = prefersDark;
      var theme = isDark ? "dark" : "light";
      var root = document.documentElement;
      root.classList.toggle("dark", isDark);
      root.dataset.theme = theme;
    } catch (_) {}
  })();
</script>
<style is:inline>
  [data-theme-icon="sun"] {
    display: none !important;
  }
  [data-theme-icon="moon"] {
    display: inline-flex !important;
  }
  html[data-theme="dark"] [data-theme-icon="sun"] {
    display: inline-flex !important;
  }
  html[data-theme="dark"] [data-theme-icon="moon"] {
    display: none !important;
  }
  [data-theme-icon] {
    transition: none !important;
  }
</style>
